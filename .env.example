# Copy this file to .env.local and fill in your values

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# For Vercel Postgres: get this from your Vercel project dashboard
# For Neon (free): get this from https://neon.tech
# For Supabase (free): get this from your project settings > Database > Connection string
DATABASE_URL=postgresql://user:password@host:5432/stockflow

# Optional: Set to 'production' on Vercel (set automatically)
NODE_ENV=development

# Auth secret - generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-key-change-this-in-production
